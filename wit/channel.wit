package manta:channel@0.1.0;

/// Types interface - shared types for channel communication
interface types {
    /// Chat types supported by the channel
    enum chat-type {
        /// Direct/private message
        direct,
        /// Group chat
        group,
        /// Channel (broadcast)
        channel,
        /// Thread/reply
        thread,
    }

    /// Channel capabilities
    record capabilities {
        /// Supported chat types (direct, group, channel, thread)
        chat-types: list<chat-type>,
        /// Supports formatted text (markdown, HTML, etc.)
        supports-formatting: bool,
        /// Supports file attachments
        supports-attachments: bool,
        /// Supports inline images
        supports-images: bool,
        /// Supports message threading/replies
        supports-threads: bool,
        /// Supports typing indicators
        supports-typing: bool,
        /// Supports reaction buttons
        supports-buttons: bool,
        /// Supports slash commands
        supports-commands: bool,
        /// Supports message reactions (emoji reactions)
        supports-reactions: bool,
        /// Supports editing messages
        supports-edit: bool,
        /// Supports deleting/unsending messages
        supports-unsend: bool,
        /// Supports special effects (confetti, etc.)
        supports-effects: bool,
    }

    /// Message attachment
    record attachment {
        filename: string,
        content-type: string,
        size: u64,
        /// Base64-encoded content
        data: string,
    }

    /// Incoming message from a channel
    record incoming-message {
        id: string,
        user-id: string,
        conversation-id: string,
        content: string,
        attachments: list<attachment>,
    }

    /// Outgoing message to send
    record outgoing-message {
        conversation-id: string,
        content: string,
        formatted-content: option<string>,
        reply-to: option<string>,
    }

    /// Message options
    record message-options {
        /// Whether to show typing indicator
        show-typing: bool,
        /// Whether to send silently
        silent: bool,
    }

    /// Channel errors
    variant channel-error {
        /// Generic error with message
        generic(string),
        /// Not configured
        not-configured,
        /// Send failed
        send-failed(string),
        /// Invalid configuration
        invalid-config(string),
        /// Not supported
        not-supported(string),
        /// Rate limited
        rate-limited(u64),
    }

    /// Result type for string operations
    variant string-result {
        ok(string),
        err(channel-error),
    }

    /// Result type for unit operations
    variant unit-result {
        ok,
        err(channel-error),
    }

    /// Result type for bool operations
    variant bool-result {
        ok(bool),
        err(channel-error),
    }
}

/// Log levels
interface logging {
    enum log-level {
        debug,
        info,
        warn,
        error,
    }
}

/// Channel interface - exported by plugins
interface channel {
    use types.{capabilities, outgoing-message, message-options, string-result, unit-result, bool-result};

    /// Initialize the channel with configuration (JSON string)
    init: func(config: string) -> string-result;

    /// Start the channel (begin receiving messages)
    start: func() -> unit-result;

    /// Stop the channel
    stop: func() -> unit-result;

    /// Get channel name
    get-name: func() -> string;

    /// Get channel capabilities
    get-capabilities: func() -> capabilities;

    /// Send a message
    send: func(message: outgoing-message, options: message-options) -> string-result;

    /// Send typing indicator
    send-typing: func(conversation-id: string) -> unit-result;

    /// Edit a message
    edit-message: func(message-id: string, new-content: string) -> unit-result;

    /// Delete a message
    delete-message: func(message-id: string) -> unit-result;

    /// Health check
    health-check: func() -> bool-result;
}

/// Host interface - callbacks the plugin can call into the host
interface host {
    use types.{incoming-message};
    use logging.{log-level};

    /// Log a message
    log: func(level: log-level, message: string);

    /// Send an incoming message to the host
    receive-message: func(message: incoming-message);

    /// Get host-provided configuration
    get-config: func() -> string;
}

/// World definition - what the plugin exports and imports
world channel-plugin {
    /// Plugin exports the channel interface
    export channel;

    /// Plugin imports the host interface
    import host;

    /// Import logging for log levels
    import logging;

    /// Import types for use in exports
    import types;
}
